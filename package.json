{
  "name": "gaminglooper",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop game-audio loop, playlist, and SE audition tool.",
  "author": "GamingLooper contributors",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "tsc -p tsconfig.electron.json && electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json && vite build",
    "test": "vitest run src",
    "dist": "npm.cmd run build && electron-builder",
    "dist:dir": "npm.cmd run build && electron-builder --dir",
    "create:shortcut": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$shell = New-Object -ComObject WScript.Shell; $shortcut = $shell.CreateShortcut((Join-Path (Get-Location) 'GamingLooper Dev.lnk')); $shortcut.TargetPath = (Join-Path (Get-Location) 'GamingLooper-dev.bat'); $shortcut.WorkingDirectory = (Get-Location).Path; $shortcut.Save()\""
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.556.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.gaminglooper.app",
    "productName": "GamingLooper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "release-template/README.txt",
        "to": "README.txt"
      },
      {
        "from": "release-template/save",
        "to": "save",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "asset/se",
        "to": "asset/se",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "dir"
      ]
    }
  }
}
